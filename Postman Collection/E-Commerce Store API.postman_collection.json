    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "// Save to environment (works with your .postman_environment.json)",
                  "if (res.token) {",
                  "    pm.environment.set('token', res.token);",
                  "    console.log('Token saved:', res.token);",
                  "} else {",
                  "    console.log('❌ No token in response:', JSON.stringify(res));",
                  "}",
                  "",
                  "if (res.user?._id) {",
                  "    pm.environment.set('user_id', res.user._id);",
                  "    console.log('User ID saved:', res.user._id);",
                  "}",
                  "",
                  "// Handle different response structures",
                  "// Some APIs return { data: { token, user } }",
                  "if (res.data?.token) {",
                  "    pm.environment.set('token', res.data.token);",
                  "    console.log('Token saved from res.data:', res.data.token);",
                  "}",
                  "if (res.data?.user?._id) {",
                  "    pm.environment.set('user_id', res.data.user._id);",
                  "}",
                  "",
                  "// Test status",
                  "pm.test('Login successful', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Token exists in response', () => {",
                  "    pm.expect(res.token || res.data?.token).to.not.be.undefined;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstName\": \"Amit\",\n    \"lastName\": \"Sain\",\n    \"email\": \"amit@gmail.com\",\n    \"password\":\"password@123\",\n    \"phone\": \"7742523708\",\n    \"role\": \"customer\"\n}"
